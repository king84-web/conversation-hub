'use client'

import { useState, useEffect } from 'react'
import Navigation from '@/components/Navigation'
import Footer from '@/components/Footer'
import Toast from '@/components/Toast'

interface User {
  id: string
  name: string
  secretKey: string
  createdAt: string
}

interface Message {
  id: string
  name: string
  email: string
  subject: string
  message: string
  createdAt: string
  type: 'inquiry' | 'feedback' | 'feedback-form'
  status: 'unread' | 'read'
}

interface AdminStats {
  totalUsers: number
  pendingApprovals: number
  totalMessages: number
  unreadMessages: number
}

const ADMIN_EMAIL = 'admin@conversationhub.com'
const ADMIN_PASSWORD = 'Steph2026Admin'

export default function AdminDashboard() {
  const [isAuthenticated, setIsAuthenticated] = useState(false)
  const [adminEmail, setAdminEmail] = useState('')
  const [adminPassword, setAdminPassword] = useState('')
  const [loginError, setLoginError] = useState('')
  const [activeTab, setActiveTab] = useState<'overview' | 'approvals' | 'messages' | 'users' | 'content'>('overview')
  const [signUpRequests, setSignUpRequests] = useState<SignUpRequest[]>([])
  const [messages, setMessages] = useState<Message[]>([])
  const [stats, setStats] = useState<AdminStats>({
    totalUsers: 0,
    pendingApprovals: 0,
    totalMessages: 0,
    unreadMessages: 0
  })

  const [cards, setCards] = useState<any[]>([])
  const [promos, setPromos] = useState<any[]>([])
  const [settingsState, setSettingsState] = useState<any>({})
  const [loading, setLoading] = useState(false)
  const [toast, setToast] = useState<string | null>(null)
  const [toastType, setToastType] = useState<'success'|'error'|'info'>('success')

  const showToast = (message: string, type: 'success'|'error'|'info' = 'success') => {
    setToastType(type)
    setToast(message)
  }

  useEffect(() => {
    const isAdmin = localStorage.getItem('isAdmin')
    if (isAdmin === 'true') {
      setIsAuthenticated(true)
      loadDashboardData()
    }
  }, [])

  // auto-refresh when approvals tab active
  useEffect(() => {
    if (activeTab === 'approvals') {
      const id = setInterval(loadDashboardData, 15000)
      return () => clearInterval(id)
    }
  }, [activeTab])

  const handleAdminLogin = (e: React.FormEvent) => {
    e.preventDefault()
    if (adminEmail === ADMIN_EMAIL && adminPassword === ADMIN_PASSWORD) {
      setIsAuthenticated(true)
      setLoginError('')
      localStorage.setItem('isAdmin', 'true')
      setAdminEmail('')
      setAdminPassword('')
      loadDashboardData()
    } else {
      setLoginError('Invalid admin email or password')
    }
  }

  // refresh data when switching tabs
  const handleTabClick = (tab: typeof activeTab) => {
    setActiveTab(tab)
    loadDashboardData()
  }

  const loadDashboardData = async () => {
    setLoading(true)
    try {
      // Fetch signups
      const signupRes = await fetch('/api/admin?action=signups')
      const signupData = await signupRes.json()
      setSignUpRequests(signupData.data || [])

      // Fetch messages
      const msgRes = await fetch('/api/admin?action=messages')
      const msgData = await msgRes.json()
      setMessages(msgData.data || [])

      // Fetch stats
      const statsRes = await fetch('/api/admin?action=stats')
      const statsData = await statsRes.json()
      setStats(statsData.data || { totalUsers: 0, pendingApprovals: 0, totalMessages: 0, unreadMessages: 0 })

      // Fetch cards and promos (for admin control)
      const cardsRes = await fetch('/api/admin?action=cards')
      const cardsData = await cardsRes.json()
      setCards(cardsData.data || [])

      const promosRes = await fetch('/api/admin?action=promos')
      const promosData = await promosRes.json()
      setPromos(promosData.data || [])

      const settingsRes = await fetch('/api/admin?action=settings')
      const settingsData = await settingsRes.json()
      setSettingsState(settingsData.data || {})
    } catch (err) {
      console.error('Failed to load dashboard data:', err)
    } finally {
      setLoading(false)
    }
  }

  const handleApproveUser = async (id: string) => {
    try {
      const response = await fetch(`/api/admin?action=approve`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      })

      if (response.ok) {
        // Update local state immediately
        setSignUpRequests(signUpRequests.map(r => 
          r.id === id ? { ...r, status: 'approved' } : r
        ))
        setStats({ ...stats, pendingApprovals: stats.pendingApprovals - 1, totalUsers: stats.totalUsers + 1 })
        showToast('User approved', 'success')
      }
    } catch (err) {
      console.error('Error approving user:', err)
    }
  }

  const handleRejectUser = async (id: string) => {
    try {
      const response = await fetch(`/api/admin?action=reject`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      })

      if (response.ok) {
        // Update local state immediately
        setSignUpRequests(signUpRequests.map(r => 
          r.id === id ? { ...r, status: 'rejected' } : r
        ))
        setStats({ ...stats, pendingApprovals: stats.pendingApprovals - 1 })
        showToast('User rejected', 'info')
      }
    } catch (err) {
      console.error('Error rejecting user:', err)
    }
  }

  const handleMarkMessageAsRead = async (id: string) => {
    try {
      const response = await fetch(`/api/admin?action=mark-read`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      })

      if (response.ok) {
        // Update local state immediately
        setMessages(messages.map(m => 
          m.id === id ? { ...m, status: 'read' } : m
        ))
        setStats({ ...stats, unreadMessages: stats.unreadMessages - 1 })
        showToast('Message marked read', 'success')
      }
    } catch (err) {
      console.error('Error marking message as read:', err)
    }
  }

  // Admin: add new card
  const handleAddCard = async (name: string, description: string, categories: string[]) => {
    try {
      const res = await fetch('/api/admin?action=add-card', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, description, categories })
      })
      if (res.ok) {
        // reload data
        loadDashboardData()
        showToast('Card added', 'success')
      }
    } catch (err) {
      console.error('Error adding card:', err)
    }
  }

  const handleAddPromo = async (title: string, content: string, image?: string) => {
    try {
      const res = await fetch('/api/admin?action=add-promo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, content, image })
      })
      if (res.ok) loadDashboardData()
      if (res.ok) showToast('Promo added', 'success')
    } catch (err) {
      console.error('Error adding promo:', err)
    }
  }

  const handleUpdateSettings = async (data: { primaryColor?: string; sponsor?: string; heroImage?: string }) => {
    try {
      const res = await fetch('/api/admin?action=update-settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      if (res.ok) loadDashboardData()
      if (res.ok) showToast('Settings updated', 'success')
    } catch (err) {
      console.error('Error updating settings:', err)
    }
  }

  const handleDeleteCard = async (id: string) => {
    try {
      const res = await fetch('/api/admin?action=delete-card', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      })
      if (res.ok) {
        setCards(cards.filter(c => c.id !== id))
        showToast('Card deleted', 'info')
      }
    } catch (err) {
      console.error('Error deleting card:', err)
    }
  }

  const handleDeletePromo = async (id: string) => {
    try {
      const res = await fetch('/api/admin?action=delete-promo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      })
      if (res.ok) {
        setPromos(promos.filter(p => p.id !== id))
        showToast('Promo deleted', 'info')
      }
    } catch (err) {
      console.error('Error deleting promo:', err)
    }
  }

  if (!isAuthenticated) {
    return (
      <>
        <Navigation />
        <main className="min-h-screen bg-gray-50 py-12">
          <div className="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
            <div className="bg-white rounded-lg shadow-md p-8">
              <h1 className="text-3xl font-bold mb-2 text-center">Admin Dashboard</h1>
              <p className="text-gray-600 text-center mb-8">
                Steph's Control Center
              </p>

              {loginError && (
                <div className="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
                  {loginError}
                </div>
              )}

              <form onSubmit={handleAdminLogin} className="space-y-6">
                <div>
                  <label className="block text-sm font-semibold mb-2">Admin Email</label>
                  <input
                    type="email"
                    value={adminEmail}
                    onChange={(e) => setAdminEmail(e.target.value)}
                    placeholder="admin@conversationhub.com"
                    className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent"
                    required
                  />
                  <p className="text-xs text-gray-500 mt-2">Email: {ADMIN_EMAIL}</p>
                </div>

                <div>
                  <label className="block text-sm font-semibold mb-2">Admin Password</label>
                  <input
                    type="password"
                    value={adminPassword}
                    onChange={(e) => setAdminPassword(e.target.value)}
                    placeholder="••••••••"
                    className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent"
                    required
                  />
                  <p className="text-xs text-gray-500 mt-2">Password: {ADMIN_PASSWORD}</p>
                </div>

                <button
                  type="submit"
                  className="w-full bg-accent text-primary px-6 py-3 rounded-lg font-bold hover:bg-opacity-90 transition"
                >
                  Access Admin Dashboard
                </button>
              </form>
            </div>
          </div>
        </main>
        <Footer />
      </>
    )
  }

  return (
    <>
      <Navigation />
      {toast && <Toast message={toast} type={toastType} onClose={() => setToast(null)} />}
      <main className="min-h-screen bg-gray-50 py-12">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex justify-between items-center mb-8">
            <div>
              <h1 className="text-4xl font-bold">Admin Dashboard</h1>
              <p className="text-gray-600">Manage users, approvals, and feedback</p>
            </div>
            <button
              onClick={() => {
                setIsAuthenticated(false)
                setAdminPassword('')
                localStorage.removeItem('isAdmin')
              }}
              className="bg-red-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-red-700"
            >
              Logout
            </button>
          </div>

          {/* Stats Overview */}
          <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div className="bg-white rounded-lg shadow-md p-6">
              <div className="text-3xl font-bold text-accent">{stats.totalUsers}</div>
              <p className="text-gray-600">Total Users</p>
            </div>
            <div className="bg-white rounded-lg shadow-md p-6">
              <div className="text-3xl font-bold text-yellow-600">{stats.pendingApprovals}</div>
              <p className="text-gray-600">Pending Approvals</p>
            </div>
            <div className="bg-white rounded-lg shadow-md p-6">
              <div className="text-3xl font-bold text-blue-600">{stats.totalMessages}</div>
              <p className="text-gray-600">Total Messages</p>
            </div>
            <div className="bg-white rounded-lg shadow-md p-6">
              <div className="text-3xl font-bold text-red-600">{stats.unreadMessages}</div>
              <p className="text-gray-600">Unread Messages</p>
            </div>
          </div>

          {/* Navigation Tabs */}
          <div className="flex gap-4 mb-8 bg-white rounded-lg shadow-md p-4 overflow-x-auto">
            <button
              onClick={() => handleTabClick('overview')}
              className={`px-6 py-2 rounded-lg font-semibold transition whitespace-nowrap ${
                activeTab === 'overview'
                  ? 'bg-accent text-primary'
                  : 'bg-gray-100 text-gray-800 hover:bg-gray-200'
              }`}
            >
              Overview
            </button>
            <button
              onClick={() => handleTabClick('approvals')}
              className={`px-6 py-2 rounded-lg font-semibold transition whitespace-nowrap ${
                activeTab === 'approvals'
                  ? 'bg-accent text-primary'
                  : 'bg-gray-100 text-gray-800 hover:bg-gray-200'
              }`}
            >
              Sign-Up Requests ({stats.pendingApprovals})
            </button>
            <button
              onClick={() => handleTabClick('messages')}
              className={`px-6 py-2 rounded-lg font-semibold transition whitespace-nowrap ${
                activeTab === 'messages'
                  ? 'bg-accent text-primary'
                  : 'bg-gray-100 text-gray-800 hover:bg-gray-200'
              }`}
            >
              Messages ({stats.unreadMessages})
            </button>
            <button
              onClick={() => handleTabClick('users')}
              className={`px-6 py-2 rounded-lg font-semibold transition whitespace-nowrap ${
                activeTab === 'users'
                  ? 'bg-accent text-primary'
                  : 'bg-gray-100 text-gray-800 hover:bg-gray-200'
              }`}
            >
              Approved Users
            </button>
            <button
              onClick={() => handleTabClick('content')}
              className={`px-6 py-2 rounded-lg font-semibold transition whitespace-nowrap ${
                activeTab === 'content'
                  ? 'bg-accent text-primary'
                  : 'bg-gray-100 text-gray-800 hover:bg-gray-200'
              }`}
            >
              Content Manager
            </button>
          </div>

          {/* Content Sections */}
          {activeTab === 'overview' && (
            <div className="bg-white rounded-lg shadow-md p-8">
              <h2 className="text-2xl font-bold mb-6">Dashboard Overview</h2>
              <div className="space-y-4 text-gray-700">
                <p className="text-lg font-semibold">Welcome to the Conversation Hub Admin Dashboard, Steph! 👋</p>
                <p className="text-gray-600">Admin Email: <span className="font-mono">{ADMIN_EMAIL}</span></p>
                <p className="text-gray-600">Password: <span className="font-mono">{ADMIN_PASSWORD}</span></p>
                
                <div className="mt-6 pt-6 border-t">
                  <p className="mb-4">From this control center, you can:</p>
                  <ul className="list-disc list-inside space-y-2 ml-4">
                    <li>Review and approve new user sign-up requests</li>
                    <li>View and respond to user feedback and inquiries</li>
                    <li>Monitor user activity and engagement</li>
                    <li>Manage card content and system settings</li>
                    <li>Track community metrics and growth</li>
                  </ul>
                </div>

                <div className="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
                  <p className="font-semibold mb-2">Recent Activity</p>
                  <p className="text-sm">You have <span className="font-bold">{stats.pendingApprovals}</span> pending user approvals and <span className="font-bold">{stats.unreadMessages}</span> unread messages.</p>
                  <p className="text-sm mt-2">Total approved users: <span className="font-bold">{stats.totalUsers}</span></p>
                </div>
              </div>
            </div>
          )}

          {activeTab === 'approvals' && (
            <div className="bg-white rounded-lg shadow-md p-8">
              <h2 className="text-2xl font-bold mb-6">Sign-Up Requests ({signUpRequests.filter(r => r.status === 'pending').length})</h2>
              {signUpRequests.filter(r => r.status === 'pending').length === 0 ? (
                <p className="text-gray-600">No pending sign-up requests</p>
              ) : (
                <div className="space-y-4">
                  {signUpRequests.filter(r => r.status === 'pending').map(request => (
                    <div key={request.id} className="border border-gray-200 p-4 rounded-lg">
                      <div className="flex justify-between items-start mb-4">
                        <div>
                          <h3 className="font-bold text-lg">{request.fullName}</h3>
                          <p className="text-sm text-gray-600">{request.email}</p>
                          {request.phone && <p className="text-sm text-gray-600">{request.phone}</p>}
                        </div>
                        <span className="text-xs bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full">
                          Pending
                        </span>
                      </div>
                      <div className="mb-4 text-sm text-gray-600">
                        <p><span className="font-semibold">Interests:</span> {request.interests}</p>
                        <p><span className="font-semibold">Applied:</span> {new Date(request.createdAt).toLocaleDateString()}</p>
                      </div>
                      <div className="flex gap-2">
                        <button
                          onClick={() => handleApproveUser(request.id)}
                          className="bg-green-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-green-700 transition"
                        >
                          Approve
                        </button>
                        <button
                          onClick={() => handleRejectUser(request.id)}
                          className="bg-red-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-red-700 transition"
                        >
                          Reject
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}

          {activeTab === 'messages' && (
            <div className="bg-white rounded-lg shadow-md p-8">
              <h2 className="text-2xl font-bold mb-6">Messages & Feedback ({messages.filter(m => m.status === 'unread').length} unread)</h2>
              {messages.length === 0 ? (
                <p className="text-gray-600">No messages yet</p>
              ) : (
                <div className="space-y-4">
                  {messages.map(msg => (
                    <div
                      key={msg.id}
                      className={`border p-4 rounded-lg ${msg.status === 'unread' ? 'border-blue-400 bg-blue-50' : 'border-gray-200'}`}
                    >
                      <div className="flex justify-between items-start mb-2">
                        <div>
                          <h3 className="font-bold">{msg.name}</h3>
                          <p className="text-sm text-gray-600">{msg.email}</p>
                        </div>
                        <div className="text-right">
                          <span className={`text-xs px-3 py-1 rounded-full ${
                            msg.type === 'inquiry' ? 'bg-purple-100 text-purple-800' :
                            msg.type === 'feedback' ? 'bg-blue-100 text-blue-800' :
                            'bg-green-100 text-green-800'
                          }`}>
                            {msg.type}
                          </span>
                          {msg.status === 'unread' && (
                            <span className="block text-xs text-blue-600 mt-1">New</span>
                          )}
                        </div>
                      </div>
                      <div className="mb-3">
                        <p className="font-semibold text-sm">{msg.subject}</p>
                        <p className="text-gray-700 mt-2">{msg.message}</p>
                      </div>
                      <div className="flex justify-between items-center text-xs text-gray-600 pt-3 border-t">
                        <span>{new Date(msg.createdAt).toLocaleDateString()} {new Date(msg.createdAt).toLocaleTimeString()}</span>
                        {msg.status === 'unread' && (
                          <button
                            onClick={() => handleMarkMessageAsRead(msg.id)}
                            className="text-blue-600 font-semibold hover:underline"
                          >
                            Mark as Read
                          </button>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}

          {activeTab === 'users' && (
            <div className="bg-white rounded-lg shadow-md p-8">
              <h2 className="text-2xl font-bold mb-6">Approved Users ({signUpRequests.filter(r => r.status === 'approved').length})</h2>
              {signUpRequests.filter(r => r.status === 'approved').length === 0 ? (
                <p className="text-gray-600">No approved users yet</p>
              ) : (
                <div className="overflow-x-auto">
                  <table className="w-full">
                    <thead className="border-b">
                      <tr>
                        <th className="text-left py-2 px-4">Name</th>
                        <th className="text-left py-2 px-4">Email</th>
                        <th className="text-left py-2 px-4">Phone</th>
                        <th className="text-left py-2 px-4">Interests</th>
                        <th className="text-left py-2 px-4">Approved Date</th>
                      </tr>
                    </thead>
                    <tbody>
                      {signUpRequests.filter(r => r.status === 'approved').map(user => (
                        <tr key={user.id} className="border-b hover:bg-gray-50">
                          <td className="py-3 px-4">{user.fullName}</td>
                          <td className="py-3 px-4 text-sm">{user.email}</td>
                          <td className="py-3 px-4 text-sm">{user.phone || '—'}</td>
                          <td className="py-3 px-4 text-sm">{user.interests}</td>
                          <td className="py-3 px-4 text-sm">{new Date(user.createdAt).toLocaleDateString()}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          )}

          {activeTab === 'content' && (
            <div className="bg-white rounded-lg shadow-md p-8">
              <h2 className="text-2xl font-bold mb-6">Content Manager</h2>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <h3 className="font-semibold mb-2">Add New Card</h3>
                  <CardForm onAdd={handleAddCard} />
                  {cards.length > 0 && (
                    <ul className="mt-4 space-y-2">
                      {cards.map(c => (
                        <li key={c.id} className="flex justify-between items-center">
                          <span>{c.name}</span>
                          <button
                            onClick={() => handleDeleteCard(c.id)}
                            className="text-red-600 hover:underline text-xs"
                          >Delete</button>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>

                <div>
                  <h3 className="font-semibold mb-2">Add Promotion / Announcement</h3>
                  <PromoForm onAdd={handleAddPromo} />
                  {promos.length > 0 && (
                    <ul className="mt-4 space-y-2">
                      {promos.map(p => (
                        <li key={p.id} className="flex justify-between items-center">
                          <span>{p.title}</span>
                          <button
                            onClick={() => handleDeletePromo(p.id)}
                            className="text-red-600 hover:underline text-xs"
                          >Delete</button>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>

              <div className="mt-6">
                <h3 className="font-semibold mb-2">Site Settings</h3>
                <SettingsForm onUpdate={handleUpdateSettings} current={settingsState} />
              </div>
            </div>
          )}
        </div>
      </main>
      <Footer />
    </>
  )
}
